# Database connection (required)
DATABASE_URL=postgresql+psycopg://rumbo_user:rumbo_pass@localhost:5432/rumbo_db

# JWT secret key (required, min 16 chars — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
SECRET_KEY=change-this-generate-a-real-secret-key-with-the-command-above

# JWT algorithm
ALGORITHM=HS256

# Token expiration in minutes (default: 1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment: development | production
ENVIRONMENT=development
